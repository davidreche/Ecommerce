<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    tools:context=".SplashScreen">

    <!-- Ícone / Logo do app (usando emoji como placeholder) -->
    <TextView
        android:id="@+id/imgLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="🛒"
        android:textSize="72sp" />

    <!-- Nome da loja -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:letterSpacing="0.05"
        android:text="MercadoFácil"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />

    <!-- Slogan -->
    <TextView
        android:id="@+id/textSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:alpha="0"
        android:gravity="center"
        android:text="Tudo que você precisa, no melhor preço!"
        android:textColor="#A5D6A7"
        android:textSize="15sp" />

    <!-- Divider -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginBottom="24dp"
        android:background="#4CAF50" />

    <!-- Banner de promoção -->
    <LinearLayout
        android:id="@+id/textPromo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="🔥 OFERTA ESPECIAL 🔥"
            android:textColor="#FFD600"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="FRETE GRÁTIS nas compras acima de R$ 150,00"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Use o cupom: MERCADO10 e ganhe 10% OFF"
            android:textColor="#C8E6C9"
            android:textSize="13sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btFixo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#225322"
        android:onClick="fixa"
        android:text="Lista FIXA" />

    <Button
        android:id="@+id/btAPI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#225322"
        android:onClick="api"
        android:text="Carrega API" />

    <!-- Rodapé -->

</LinearLayout>