<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabeçalho -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Finalizar Pedido"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Card: Total -->
        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/textTotalPagamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="Total a pagar: R$ 0,00"
                android:textColor="#1B5E20"
                android:textSize="20sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <!-- Seletor de método de pagamento -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="Escolha a forma de pagamento:"
            android:textColor="#444"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMetodoCartao"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#4CAF50"
                android:text="💳 Cartão"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnMetodoPix"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#9E9E9E"
                android:text="⚡ PIX"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ===== SEÇÃO CARTÃO DE CRÉDITO ===== -->
        <LinearLayout
            android:id="@+id/secaoCartao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Dados do Cartão"
                        android:textColor="#333"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Número do cartão -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Número do Cartão"
                        android:textColor="#777"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editNumeroCartao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="0000 0000 0000 0000"
                        android:inputType="number"
                        android:maxLength="16" />

                    <!-- Nome do titular -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome do Titular"
                        android:textColor="#777"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editNomeTitular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Como no cartão"
                        android:inputType="textPersonName" />

                    <!-- Validade e CVV lado a lado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Validade"
                                android:textColor="#777"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/editValidade"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="MM/AA"
                                android:inputType="number"
                                android:maxLength="5" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CVV"
                                android:textColor="#777"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/editCvv"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="000"
                                android:inputType="numberPassword"
                                android:maxLength="4" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Botão pagar -->
                    <Button
                        android:id="@+id/btnPagarCartao"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="#4CAF50"
                        android:text="✅ Pagar com Cartão"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ===== SEÇÃO PIX ===== -->
        <LinearLayout
            android:id="@+id/secaoPix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="⚡ Pague com PIX"
                        android:textColor="#333"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        app:srcCompat="@drawable/qrcode" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Escaneie o QR Code abaixo:"
                        android:textColor="#666"
                        android:textSize="14sp" />

                    <!-- QR Code fake (nossa custom view) -->

                    <!-- Ou copiar chave PIX -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Ou copie a chave PIX:"
                        android:textColor="#777"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/textChavePix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="mercadofacil@pagamentos.com.br"
                        android:textColor="#1565C0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="⚠️ Este QR Code é fictício e gerado apenas para fins didáticos."
                        android:textColor="#F57F17"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnConfirmarPix"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="#1B5E20"
                        android:text="✅ Já realizei o pagamento"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Espaço no rodapé -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>